# Avatar RPG — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Supabase project URL (from Settings > API)
SUPABASE_URL=https://your-project.supabase.co

# Service role key — full access, server-side only
# (Settings > API > Project API keys > service_role)
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Anon key — public, used for user-scoped clients
# (Settings > API > Project API keys > anon public)
SUPABASE_ANON_KEY=your-anon-key-here
